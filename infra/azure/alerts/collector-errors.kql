// Fires when the hub or telemetry gateway logs a collector.event with
// level=error within the last hour (e.g. the gateway's own upstream-forward
// failures — see hub/gateway/telemetry-gateway.ts's `collector.event` log line
// — or collector-reported machine-side errors relayed through the hub).
//
// See missed-heartbeat.kql for the OTelLogs/Body-as-JSON assumption this query
// shares. ASSUMPTION TO VERIFY AT M4 DEPLOY: confirm the table/column names
// once real data flows, and confirm `level` (not `severity` or the OTLP-native
// SeverityText column) is the field the JSON payload actually uses.

OTelLogs
| where TimeGenerated > ago(1h)
| extend body = todynamic(Body)
| where body.event == "collector.event" and body.level == "error"
| project TimeGenerated, body
