{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sessions-hub",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "limits": { "cpu_ms": 300000 },
  // Routes activated in M3. Implemented as Workers Custom Domains (not zone
  // `routes` with `zone_name`) because the deploy credential is an OAuth token
  // without a dns_records scope: custom domains are provisioned through the
  // Workers API (Cloudflare manages the proxied DNS record + edge cert itself),
  // whereas a zone route requires a pre-existing proxied DNS record we cannot
  // create with this token. Both hostnames stay fully proxied on the vza.net
  // zone, so API Shield mTLS + the WAF cert-verified rule apply identically.
  "routes": [
    { "pattern": "api.sessions.vza.net", "custom_domain": true },
    { "pattern": "sessions.vza.net", "custom_domain": true }
  ],
  "account_id": "18ef3246e9f36d1560485ef53889c0ab",
  // Fail-closed default: an un-configured `wrangler deploy` (no env override) must NOT
  // accept the x-dev-machine dev-auth header (see src/auth/identity.ts). Local development
  // overrides this via `npm run dev` (--var ENVIRONMENT:development); vitest overrides it
  // via vitest.config.ts's miniflare bindings, independent of this file.
  "vars": {
    "ENVIRONMENT": "production",
    "API_HOST": "api.sessions.vza.net",
    "VIEWER_HOST": "sessions.vza.net"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sessions-index",
      "database_id": "5ff65cf3-89c8-4fe6-a3c2-a370293ecea6",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [{ "binding": "RAW", "bucket_name": "agent-sessions-raw" }],
  "kv_namespaces": [{ "binding": "KV", "id": "61505c2df55242daa2f572c188819961" }],
  "queues": {
    "producers": [{ "binding": "PARSE_QUEUE", "queue": "parse" }],
    "consumers": [
      {
        "queue": "parse",
        "max_batch_size": 5,
        "max_retries": 3,
        // Serial, not concurrent: closes the canonical-selection TOCTOU window between the
        // post-parse recheck and the write (consumer.ts) rather than just narrowing it. Parse
        // throughput is a few files per 15-minute batch at steady state, and backfill tolerates
        // serial processing — this is not a throughput-sensitive path.
        "max_concurrency": 1,
        "dead_letter_queue": "parse-dlq"
      }
    ]
  },
  "triggers": { "crons": ["*/15 * * * *", "30 4 * * *"] },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
    // M4: once sessions-telemetry-gateway is deployed, add
    // "logs": { "enabled": true, "destinations": ["agent-backup-azure-logs"] } and
    // "traces": { "enabled": true, "destinations": ["agent-backup-azure-traces"] } here.
    // Destinations are ACCOUNT-level (not per-worker) and, as of this writing,
    // dashboard-only — no wrangler/API command creates them. Create them once in
    // the Cloudflare dashboard (Workers & Pages → Observability → Pipelines → Add
    // destination): Destination Type "Logs" / "Traces", OTLP Endpoint
    // https://sessions-telemetry-gateway.<account>.workers.dev/v1/{logs,traces},
    // custom header Authorization: Bearer <INGEST_BEARER>. Then reference the
    // destination names above. Full steps + trap (destinations are shared with
    // every worker on this Cloudflare account) in infra/cf/telemetry.md.
  },
  // PR preview isolation. Workers Builds runs non-production branches with
  // `wrangler versions upload`, which uses the TOP-LEVEL bindings unless an env is
  // selected — i.e. a preview would run unreviewed PR code against PRODUCTION D1/R2/
  // KV/queues. Non-production Builds MUST set the deploy command to `--env preview`
  // (see infra/cf/deploy.md). This block redeclares EVERY binding against the -preview
  // resource set — wrangler does NOT inherit bindings into named environments, so each
  // must be restated — and pins ENVIRONMENT='preview', which turns on the DEV_AUTH
  // bearer gate (src/auth/identity.ts) so the public *.workers.dev preview URL is not
  // unauthenticated. `--env preview` also names the worker `sessions-hub-preview`, a
  // separate Worker from production. No routes/custom domains: previews serve from their
  // workers.dev version URL, where zone mTLS/WAF don't apply (hence the bearer gate).
  // DEV_AUTH is a per-env secret: `wrangler secret put DEV_AUTH --env preview`.
  "env": {
    "preview": {
      // Empty on purpose: unlike bindings, `routes` IS inherited into named environments,
      // so without this a preview deploy would REASSIGN the production custom domains
      // (api./sessions.vza.net) to sessions-hub-preview. Previews serve from workers.dev.
      "routes": [],
      "vars": {
        "ENVIRONMENT": "preview",
        "API_HOST": "api.sessions.vza.net",
        "VIEWER_HOST": "sessions.vza.net"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "sessions-index-preview",
          "database_id": "8f2cd488-0060-4f32-8025-f5b461c9fe0a",
          "migrations_dir": "migrations"
        }
      ],
      "r2_buckets": [{ "binding": "RAW", "bucket_name": "agent-sessions-raw-preview" }],
      "kv_namespaces": [{ "binding": "KV", "id": "eda3b8a8ba1e416fa65e98d0c266a4bb" }],
      "queues": {
        "producers": [{ "binding": "PARSE_QUEUE", "queue": "parse-preview" }],
        "consumers": [
          {
            "queue": "parse-preview",
            "max_batch_size": 5,
            "max_retries": 3,
            "max_concurrency": 1,
            "dead_letter_queue": "parse-dlq-preview"
          }
        ]
      },
      "triggers": { "crons": ["*/15 * * * *", "30 4 * * *"] },
      "observability": { "enabled": true, "head_sampling_rate": 1 }
    }
  }
  // secrets: SETUP_TOKEN (passkey bootstrap), CF_API_TOKEN (cert renewal);
  // preview env: DEV_AUTH (bearer gate) via `wrangler secret put DEV_AUTH --env preview`
}
