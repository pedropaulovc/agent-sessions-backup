{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sessions-oidc-issuer",
  "main": "gateway/oidc-issuer.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "upload_source_maps": true,
  // Public OIDC issuer. ISSUER_URL must equal this worker's own public URL and
  // match: sessions-telemetry-gateway's OIDC_ISSUER_URL, and the Azure federated-
  // credential `issuer` (infra/azure/provision.sh). The kid in the embedded JWK
  // (gateway/oidc-issuer.ts) must match OIDC_SIGNING_KID on the gateway.
  //
  // ISSUER_URL is this worker's own deployed URL (workers.dev subdomain
  // pedro-18e, account 18ef3246e9f36d1560485ef53889c0ab). Must stay byte-for-byte
  // identical to sessions-telemetry-gateway's OIDC_ISSUER_URL and the Azure
  // federated-credential `issuer` (infra/azure/provision.sh argument).
  "vars": {
    "ISSUER_URL": "https://sessions-oidc-issuer.pedro-18e.workers.dev"
  }
}
