{
  "name": "sessions-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --var ENVIRONMENT:development",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate:local": "wrangler d1 migrations apply sessions-index --local",
    "migrate:remote": "wrangler d1 migrations apply sessions-index --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260717.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.111.0"
  },
  "dependencies": {
    "@simplewebauthn/server": "13.3.2"
  }
}
