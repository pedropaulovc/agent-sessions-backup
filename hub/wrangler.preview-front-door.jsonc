{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sessions-preview-front-door",
  "main": "gateway/preview-front-door.ts",
  "compatibility_date": "2026-07-01",
  // Required for Worker-to-Worker fetches through the target's public workers.dev
  // branch alias. Without it Cloudflare rejects the subrequest with error 1042.
  "compatibility_flags": ["global_fetch_strictly_public"],
  "workers_dev": false,
  "preview_urls": false,
  "account_id": "18ef3246e9f36d1560485ef53889c0ab",
  // A Workers route, rather than a Custom Domain, is required because Custom Domains
  // require exact hostnames. The wildcard DNS record is a one-time prerequisite documented
  // in infra/cf/deploy.md; the existing *.sessions.vza.net certificate covers this host.
  "routes": [
    { "pattern": "*-preview.sessions.vza.net/*", "zone_name": "vza.net" }
  ],
  "observability": { "enabled": true, "head_sampling_rate": 1 }
}
